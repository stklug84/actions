---
# Generated by stklug84/actions cv/parse — do not edit by hand.
# Source of truth: data/cv.yml (bilingual). This file is the web view
# (English, targets containing `web`) in skcloud's cv.yml schema.
name: {{ name | yamlstr }}
title: {{ title | yamlstr }}
location: {{ location | yamlstr }}
summary: {{ summary | yamlstr }}

roles:
{% for r in roles %}
  - period: {{ r.period | yamlstr }}
    year: {{ r.year }}
    role: {{ r.role | yamlstr }}
    org: {{ r.org | yamlstr }}
    location: {{ r.location | yamlstr }}
    kind: {{ r.kind | yamlstr }}
    monogram: {{ r.monogram | yamlstr }}
{% if r.bg %}
    bg: {{ r.bg | yamlstr }}
{% endif %}
{% if r.logo %}
    logo: {{ r.logo | yamlstr }}
{% endif %}
    summary: {{ r.summary | yamlstr }}
    tags: [{% for t in r.tags %}{{ t | yamlstr }}{% if not loop.last %}, {% endif %}{% endfor %}]
    bullets:
{% for b in r.bullets %}
      - {{ b | yamlstr }}
{% endfor %}
{% endfor %}

certifications:
{% for c in certifications %}
  - {{ c | yamlstr }}
{% endfor %}

skills:
{% for g in skills %}
  - group: {{ g.group | yamlstr }}
    items: [{% for s in g['items'] %}{{ s | yamlstr }}{% if not loop.last %}, {% endif %}{% endfor %}]
{% endfor %}
